// Schéma Prisma — programmation cinéma (v7)
//
// v6 : génération automatique par quotas (Film, Semaine, Seance — 4 blocs fixes).
// v7 : ajout de Placement, pour le mode manuel "Programmation" (glisser-déposer,
// horaire libre à la minute, indépendant des blocs et des semaines ISO — un
// Placement est rattaché à un jour de la semaine (récurrent), pas à une date précise).
//
// Les deux modes coexistent et ne se marchent pas dessus : Seance appartient au
// générateur automatique, Placement au mode manuel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Film {
  id             String   @id @default(cuid())
  titre          String
  dureeMinutes   Int
  classification String?  // null = tous publics ; sinon "12", "16", "18" (âge minimum)
  createdAt      DateTime @default(now())

  seances        Seance[]
  placements     Placement[]
}

model Semaine {
  id        String   @id @default(cuid())
  anneeIso  Int
  numeroIso Int
  createdAt DateTime @default(now())

  seances   Seance[]

  @@unique([anneeIso, numeroIso])
}

enum Jour {
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
  DIMANCHE
  LUNDI
  MARDI
}

model Seance {
  id          String   @id @default(cuid())
  jour        Jour
  salleIndex  Int      // 0 = Salle 1, 1 = Salle 2 (fixe, plus de table Salle)
  blocNom     String   // "matin" | "aprem" | "soir1" | "soir2" (fixe, plus de table Bloc)
  heureDebut  String   // horaire réel calculé, avec décalage éventuel (+15/+30 min)
  genereAuto  Boolean  @default(true)

  film        Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId      String

  semaine     Semaine  @relation(fields: [semaineId], references: [id], onDelete: Cascade)
  semaineId   String

  @@unique([salleIndex, blocNom, jour, semaineId])
}

// Séance placée à la main dans l'onglet "Programmation" (glisser-déposer).
// Récurrente par jour de la semaine — pas de notion de semaine ISO ni de bloc :
// l'heure de début est libre, à la minute près, sur 00:00-23:59.
model Placement {
  id         String   @id @default(cuid())
  jour       Jour
  salleIndex Int      // 0 = Salle 1, 1 = Salle 2
  heureDebut Int      // minutes depuis minuit (0-1439)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  film       Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId     String

  @@index([jour, salleIndex])
}
