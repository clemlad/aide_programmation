// Schéma Prisma — programmation cinéma (v10)
//
// v10 : suppression complète de la génération automatique.
//  - Film.seancesParSemaine supprimé : plus de quota, la programmation est
//    entièrement manuelle.
//  - Modèle Seance supprimé : il ne servait qu'à stocker le résultat de la
//    génération automatique (onglet "Générer", supprimé).
//  - Aucune notion d'événement spécial, de marge minimale ou de jour
//    particulier n'est modélisée : tous les jours sont traités de façon
//    identique et seule la non-superposition dans une même salle est vérifiée
//    (voir lib/planning-utils.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Film {
  id             String   @id @default(cuid())
  titre          String
  dureeMinutes   Int
  classification String? // null = tous publics ; sinon "12", "16", "18" (âge minimum)
  createdAt      DateTime @default(now())

  placements Placement[]
}

enum Jour {
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
  DIMANCHE
  LUNDI
  MARDI
}

// Séance placée à la main dans l'onglet "Programmation" (glisser-déposer).
// Récurrente par jour de la semaine, rattachée à l'une des deux semaines
// indépendantes (1 ou 2).
model Placement {
  id         String   @id @default(cuid())
  semaine    Int      @default(1) // 1 ou 2
  jour       Jour
  salleIndex Int // 0 = Salle 1, 1 = Salle 2
  heureDebut Int // minutes depuis minuit (0-1439)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  film   Film   @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId String

  @@index([semaine, jour, salleIndex])
}
