// Schéma Prisma — programmation cinéma (v6)
//
// Plus de tables de configuration (Salle, Bloc, BlocHoraireDefaut, ExceptionHoraire) :
// les 2 salles et les 4 blocs horaires fixes sont codés en dur dans lib/scheduler.ts.
// Rien à configurer via l'UI — seuls Film et Seance persistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Film {
  id             String   @id @default(cuid())
  titre          String
  dureeMinutes   Int
  classification String?  // null = tous publics ; sinon "12", "16", "18" (âge minimum)
  createdAt      DateTime @default(now())

  seances        Seance[]
}

model Semaine {
  id        String   @id @default(cuid())
  anneeIso  Int
  numeroIso Int
  createdAt DateTime @default(now())

  seances   Seance[]

  @@unique([anneeIso, numeroIso])
}

enum Jour {
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
  DIMANCHE
  LUNDI
  MARDI
}

model Seance {
  id          String   @id @default(cuid())
  jour        Jour
  salleIndex  Int      // 0 = Salle 1, 1 = Salle 2 (fixe, plus de table Salle)
  blocNom     String   // "matin" | "aprem" | "soir1" | "soir2" (fixe, plus de table Bloc)
  heureDebut  String   // horaire réel calculé, avec décalage éventuel (+15/+30 min)
  genereAuto  Boolean  @default(true)

  film        Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId      String

  semaine     Semaine  @relation(fields: [semaineId], references: [id], onDelete: Cascade)
  semaineId   String

  @@unique([salleIndex, blocNom, jour, semaineId])
}
